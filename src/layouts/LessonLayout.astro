---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Quiz from '../components/Quiz.astro';
import CompoundCalc from '../components/CompoundCalc.astro';
import AprApyCalc from '../components/AprApyCalc.astro';
import CardInterestCalc from '../components/CardInterestCalc.astro';
import MinPaymentCalc from '../components/MinPaymentCalc.astro';
import AmortizationCalc from '../components/AmortizationCalc.astro';
import PayoffCalc from '../components/PayoffCalc.astro';
import { curriculum } from '../data/curriculum';
import { CALCULATOR_NAMES } from '../data/calculators';

interface Props {
  entry: CollectionEntry<'lessons'>;
  prev?: CollectionEntry<'lessons'> | null;
  next?: CollectionEntry<'lessons'> | null;
  /** Estimated read time in minutes, computed from the body word count by [...slug].astro. */
  readMinutes?: number;
}
const { entry, prev = null, next = null, readMinutes = 4 } = Astro.props;
const d = entry.data;
const track = curriculum.find((t) => t.track === d.track);
const phase = track?.phases.find((p) => p.phase === d.phase);

// calculator name -> island component (D-01/D-02). A lesson opts in with
// `calculator: <name>` in frontmatter; the matching island renders in the
// .lesson-calc slot below (after the body, before "Do it").
// This map must import its components (that's why it can't live in the shared
// calculators.ts data module), but its KEYS must exactly equal CALCULATOR_NAMES —
// the single source of truth that config.ts's z.enum and validate-content.mjs also
// derive from (Phase 4 D-14). The assertion below fails the build if they drift.
const CALCULATORS = {
  compound: CompoundCalc,
  'apr-apy': AprApyCalc,
  'card-interest': CardInterestCalc,
  'min-payment': MinPaymentCalc,
  amortization: AmortizationCalc,
  payoff: PayoffCalc,
};
const calcKeys = Object.keys(CALCULATORS);
if (
  calcKeys.length !== CALCULATOR_NAMES.length ||
  !CALCULATOR_NAMES.every((name) => Object.prototype.hasOwnProperty.call(CALCULATORS, name))
) {
  throw new Error(
    `LessonLayout CALCULATORS registry keys [${calcKeys.join(', ')}] must exactly equal ` +
      `CALCULATOR_NAMES [${CALCULATOR_NAMES.join(', ')}] (src/data/calculators.ts). ` +
      `Add the missing island component or remove the stale key.`
  );
}
const Calculator = d.calculator ? CALCULATORS[d.calculator] : null;
---

<BaseLayout title={`${d.title} · Learn Personal Finance from Scratch`} description={d.summary} ogType="article">
  <article class="lesson">
    <p class="lesson-eyebrow">
      <a href="/catalog">Track {d.track} · {track?.name}</a> &nbsp;→&nbsp; Phase {d.phase}: {phase?.title}
    </p>
    <h1 class="lesson-title">
      {d.title}
      {d.mechanics && <span class="gear" title="How it actually works">⚙</span>}
    </h1>
    <p class="lesson-summary">{d.summary}</p>
    <p class="lesson-meta">Lesson {d.id} · Last reviewed {d.lastReviewed} · ~{readMinutes} min read</p>

    <div class="lesson-body">
      <slot />
    </div>

    {
      Calculator && (
        <section class="lesson-calc">
          <Calculator />
        </section>
      )
    }

    <section class="do-it">
      <h2>Do it</h2>
      <p>{d.doIt}</p>
    </section>

    <Quiz questions={d.quiz} />

    <section class="keep-this">
      <h2>Keep this</h2>
      <p>{d.keepThis}</p>
    </section>

    {
      d.sources.length > 0 && (
        <section class="sources">
          <h2>Sources</h2>
          <ul>
            {d.sources.map((s) => (
              <li>
                <a href={s.url} rel="noopener" target="_blank">
                  {s.label} ↗
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <div class="lesson-actions">
      <button type="button" class="mark-done" data-slug={entry.slug}>Mark as done</button>
    </div>

    <nav class="lesson-nav">
      {prev ? <a class="nav-prev" href={`/lessons/${prev.slug}`}>← {prev.data.title}</a> : <span></span>}
      {next ? <a class="nav-next" href={`/lessons/${next.slug}`}>{next.data.title} →</a> : <span></span>}
    </nav>
  </article>
</BaseLayout>

<style>
  /* .lesson-calc is a card PEER of .do-it / .keep-this / .quiz / .sources — same
     recipe (global.css line ~137) so it reads as part of the lesson loop, not a
     foreign widget (UI-SPEC Spacing). The island itself adds its own scoped
     internals; this wrapper supplies the shared card chrome. */
  .lesson-calc {
    /* margin-block (NOT the `margin` shorthand): the shorthand compiles with the
       scoped [data-astro-cid] specificity AND resets margin-inline:0, which would
       silently kill the global D-16 breakout rule (global.css). Pitfall 1. */
    margin-block: 2rem;
    padding: 1.1rem 1.2rem;
    border-radius: 10px;
    border: 1px solid var(--line);
    border-left: 4px solid var(--accent);
    background: var(--card);
  }
</style>

<script>
  // Progress saved in the browser only — no signup, no server.
  // All localStorage logic lives in src/lib/progress.ts (the single key owner).
  import { isDone, toggle } from '../lib/progress.ts';
  document.querySelectorAll<HTMLButtonElement>('.mark-done').forEach((btn) => {
    const slug = btn.dataset.slug || '';
    const sync = () => {
      const done = isDone(slug);
      btn.textContent = done ? '✓ Done' : 'Mark as done';
      btn.toggleAttribute('data-done', done);
    };
    sync();
    btn.addEventListener('click', () => {
      toggle(slug);
      sync();
    });
  });
</script>
